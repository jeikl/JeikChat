# JeikChat 智能客服系统 本地环境变量配置
# ============================================

# ==================== 模式配置 ====================
# 运行环境: dev (开发) / local (本地)
AICHAT_ENVIRONMENT=local

# ==================== 启动配置 ====================
# 后端服务
JEIKCHAT_BACKEND_HOST=::
JEIKCHAT_BACKEND_PORT=8000
JEIKCHAT_API_DOCS_HOST=::
JEIKCHAT_API_DOCS_PORT=8000

# 前端服务
JEIKCHAT_FRONTEND_HOST=::
JEIKCHAT_FRONTEND_PORT=5173

# 开发模式
JEIKCHAT_DEV_MODE=true

# ==================== 应用配置 ====================
APP_NAME=JeikChat
APP_VERSION=3.0.0
DATABASE_URL=sqlite:///./aichat_local.db
DEFAULT_LLM_PROVIDER=openai

# ==================== LLM 模型配置 ====================
# OpenAI配置
OPENAI_API_KEY=your-local-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_DISPLAY_NAME=OPENAI_MODEL

# Anthropic配置 (可选)
ANTHROPIC_API_KEY=your-local-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_DISPLAY_NAME=ANTHROPIC_MODEL

# Google配置 (可选)
GOOGLE_API_KEY=your-local-google-api-key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_DISPLAY_NAME=GOOGLE_MODEL

# 阿里云通义千问配置 (可选)
QWEN_API_KEY=your-local-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-max
QWEN_DISPLAY_NAME=QWEN_MODEL

# 字节跳动豆包配置 (可选)
DOUBAO_API_KEY=your-local-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_MODEL=doubao-pro
DOUBAO_DISPLAY_NAME=DOUBAO_MODEL

# 月之暗面Kimi配置 (可选)
MOONSHOT_API_KEY=your-local-moonshot-api-key
MOONSHOT_BASE_URL=https://api.moonshot.cn
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_DISPLAY_NAME=MOONSHOT_MODEL

# 智谱AI配置 (可选)
ZHIPU_API_KEY=your-local-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn
ZHIPU_MODEL=glm-4-air
ZHIPU_DISPLAY_NAME=ZHIPU_MODEL

# 百度文心一言配置 (可选)
BAIDU_API_KEY=your-local-baidu-api-key
BAIDU_SECRET_KEY=your-local-baidu-secret-key
BAIDU_BASE_URL=https://aip.baidubce.com
BAIDU_MODEL=ernie-bot-4.5
BAIDU_DISPLAY_NAME=BAIDU_MODEL

# 讯飞星火配置 (可选)
XFYUN_API_KEY=your-local-xfyun-api-key
XFYUN_SECRET_KEY=your-local-xfyun-secret-key
XFYUN_APP_ID=your-local-xfyun-app-id
XFYUN_BASE_URL=https://spark-api-open.xf-yun.com
XFYUN_MODEL=spark-4.5-ultra
XFYUN_DISPLAY_NAME=XFYUN_MODEL

# Ollama本地部署配置 (可选)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b
OLLAMA_DISPLAY_NAME=OLLAMA_MODEL

# ==================== 向量数据库配置 ====================
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_STORE_TYPE=chroma

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ==================== 文本分割配置 ====================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==================== CORS配置 ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
