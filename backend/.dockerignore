# Python 虚拟环境和相关
.venv
venv
env
.env
.env.*
.venv*
venv*
__pycache__/
*.pyc
*.pyo
*.pyd
*.Python
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt
uvlock.db               # uv 有时会生成这个调试文件

# Node / 前端构建产物（如果 frontend 有）
node_modules/
frontend/node_modules/
frontend/.next/         # 如果是 Next.js
frontend/dist/          # 如果是 Vite/React/Vue 等
frontend/build/

# 测试、日志、临时
logs/
*.log
coverage/
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# 编辑器 / IDE
.vscode/
.idea/
*.sublime-*
