*.swo

# 系统 / macOS / Windows
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Git
.git
.gitignore              # 这个其实可以不忽略，但很多人习惯忽略

# 其他项目特定大文件（看你情况加）
*.db                    # 如果有本地 sqlite 测试库
*.sqlite3
media/                  # 如果有用户上传文件测试目录
staticfiles/            # Django 收集的静态文件（如果有）