# JeikChat 智能客服系统 环境变量配置
# ============================================
# 统一配置文件 - 包含前后端所有配置

# ==================== 模式配置 ====================
AICHAT_ENVIRONMENT=dev

# ==================== 后端服务配置 ====================
JEIKCHAT_BACKEND_HOST=::
JEIKCHAT_BACKEND_PORT=8000
JEIKCHAT_API_DOCS_HOST=::
JEIKCHAT_API_DOCS_PORT=8000

# ==================== 前端服务配置 ====================
# (VITE_ 前缀会被 Vite 和 CLI 同时读取)
VITE_FRONTEND_HOST=::
VITE_FRONTEND_PORT=5173

# ==================== 开发模式 ====================
JEIKCHAT_DEV_MODE=true

# ==================== 应用配置 ====================
APP_NAME=JeikChat
APP_VERSION=3.0.0
DATABASE_URL=sqlite:///./aichat.db
DEFAULT_LLM_PROVIDER=openai
UPLOAD_DIR=./uploads

# ==================== API 地址配置 ====================
# 前端调用后端的API地址 (开发环境用 localhost，生产环境用实际域名)
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ==================== LLM 模型配置 ====================


ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_DISPLAY_NAME=ANTHROPIC_MODEL

GOOGLE_API_KEY=your-google-api-key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_DISPLAY_NAME=GOOGLE_MODEL

QWEN_API_KEY=sk-0bcb72d37754406c80b74211c3402d5d
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL="qwen3.5-plus|qwen3-max|qwen3-coder-pluss"
QWEN_DISPLAY_NAME=QWEN_MODEL
