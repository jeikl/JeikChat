# JeikChat 智能客服系统 环境变量配置
# ============================================
# 统一配置文件 - 包含前后端基础配置
JEIKCHAT_DEV_MODE=true

# ==================== 模式配置 ====================
AICHAT_ENVIRONMENT=dev
# ==================== 前端服务配置 ====================
# (VITE_ 前缀会被 Vite 和 CLI 同时读取)
VITE_FRONTEND_HOST=::
VITE_FRONTEND_PORT=5173
# ==================== 后端服务配置 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== API 地址配置 ====================
# 前端调用后端的API地址 (开发环境用 localhost，生产环境用实际域名)
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
# ==================== 开发模式 ====================


# ==================== 应用配置 ====================
APP_NAME=JeikChat
APP_VERSION=3.0.0

# ==================== 数据库配置 ====================
DB_URL=postgresql://root:anhuang520@pan.junv.top:5432/postgres?sslmode=disable